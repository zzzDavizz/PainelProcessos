{
  "name": "dasboard-gerencial-de-processos",
  "private": true,
  "scripts": {
    "postinstall": "npm install --prefix ./dashboard-mvp",
    "clean": "npm run clean --prefix ./dashboard-mvp",
    "dev": "npm run dev --prefix ./dashboard-mvp",
    "dev:clean": "npm run clean --prefix ./dashboard-mvp && npm run dev --prefix ./dashboard-mvp",
    "build": "npm run build --prefix ./dashboard-mvp",
    "postbuild": "node ./scripts/vercel-monorepo-sync.mjs",
