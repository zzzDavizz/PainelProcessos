    "lint": "npm run lint --prefix ./dashboard-mvp",
    "install:app": "npm install --prefix ./dashboard-mvp"
  },
  "dependencies": {
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
