# URL do CSV gerado pelo Apps Script (ficheiro no Google Drive).
# Ex.: https://drive.google.com/uc?export=download&id=SEU_FILE_ID
# O ficheiro tem de estar acessível ao servidor (ex.: "Qualquer pessoa com o link – leitor").
PAINEL_CSV_URL=

# Login do painel (obrigatório em produção; replicar na Vercel — o .env.local não sobe no deploy).
AUTH_LOGIN_USERNAME=
AUTH_LOGIN_PASSWORD=
# Segredo para assinar o cookie de sessão (string longa aleatória, ex.: openssl rand -hex 32).
AUTH_SESSION_SECRET=
